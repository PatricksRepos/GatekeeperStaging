#Example .env - use as tempalte. for our unit/features/e2e and manual tests

APP_NAME=Gatekeeper
APP_ENV=testing
APP_KEY=base64:EwldgCI+W7ZMK2wd9caH9alZppy4b3y60Sd8iEd0z0k=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Connection for Testing
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=gatekeeper_testing
DB_USERNAME=root
DB_PASSWORD=123456

# Cache, Session, Queue for Testing
CACHE_DRIVER=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

# Mail Configuration (disabled during testing)
MAIL_MAILER=array
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Redis Configuration for Testing
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
