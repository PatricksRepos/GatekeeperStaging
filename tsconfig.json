{
  "compilerOptions": {
    "target": "ES2020",                     // Set target to ES2020 for better support with modern JavaScript
    "module": "ES2020",                     // Use ES modules
    "moduleResolution": "Node",             // Use Node.js module resolution
    "esModuleInterop": true,                // Enable interop between CommonJS and ES Modules
    "skipLibCheck": true,                   // Skip type checking of all declaration files
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist"                      // Specify the output directory for transpiled code
  },
  "include": [
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
